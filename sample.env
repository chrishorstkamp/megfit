# --- Database (Neon PostgreSQL) ---
# Pooled connection (with -pooler in the host) — used by the app at runtime.
# The pgbouncer=true flag is required: Neon's pooler runs PgBouncer in
# transaction mode, which breaks prepared statements unless this is set.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"

# Direct connection (no -pooler) — used by the Prisma CLI for migrations.
# Prisma Migrate does not work through PgBouncer, so this must be the direct host.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# Can be generated using `npx auth secret` (compulsory)
AUTH_SECRET="xxxxxxxx"

# The following are not compulsory (if having direct DB access)
# See src/lib/utils/userCreation.ts to create users directly (run in to get a test user)

# https://authjs.dev/getting-started/providers/github
AUTH_GITHUB_ID="xxxxxx"
AUTH_GITHUB_SECRET="xxxxxx"

# https://authjs.dev/getting-started/providers/google 
AUTH_GOOGLE_ID="xxxxxx"
AUTH_GOOGLE_SECRET="xxxxxx"
